generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  progress      UserProgress[]
  streak        UserStreak?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  description      String
  difficulty       String
  category         String
  estimatedMinutes Int
  prerequisites    String   @default("[]")
  starterCode      String
  expectedOutput   String?
  tags             String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  progress UserProgress[]
}

model ConceptPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  content     String
  codeExample String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress UserProgress[]
}

model UserProgress {
  id            String    @id @default(cuid())
  userId        String
  projectId     String?
  conceptPageId String?
  status        String
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conceptPage ConceptPage? @relation(fields: [conceptPageId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@unique([userId, conceptPageId])
}

model UserStreak {
  id            String    @id @default(cuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SandboxExecution {
  id         String   @id @default(cuid())
  userId     String?
  code       String
  status     String
  stdout     String?
  stderr     String?
  durationMs Int?
  createdAt  DateTime @default(now())
}
